# Environment variables template
# Copy this file to .env.local and fill the values.
# Placeholder values are ignored by the app, so incomplete local setup keeps
# the contact form disabled instead of trying to initialize Firebase.
# For GitHub Pages production builds, set the same names in
# GitHub: Settings -> Secrets and variables -> Actions -> Repository secrets.

# Firebase Configuration
# Get these from: https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
VITE_FIREBASE_DATABASE_URL=your_database_url_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id_here

# reCAPTCHA v3 Configuration (optional; Essentials has a free monthly quota)
# Client-side site key only. Do not place a secret key in this frontend app.
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
