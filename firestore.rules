rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if the requesting user is an admin according to admins collection
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.isAdmin == true;
    }

    // Admins collection: allow users to read their own admin doc; allow admins to manage admins
    match /admins/{adminId} {
      allow read: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      allow create: if request.auth != null && (request.auth.uid == adminId || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Content collections used by the app: public reads, writes only for admins
    match /{collection}/{docId} {
      allow read: if collection in [
        'portfolio',
        'skills',
        'projects',
        'experience',
        'education',
        'achievements',
        'socialLinks'
      ];
      allow create, update, delete: if isAdmin() && collection in [
        'portfolio',
        'skills',
        'projects',
        'experience',
        'education',
        'achievements',
        'socialLinks'
      ];
    }

    // Analytics events: allow clients to write, but only admins can read
    match /analytics/{eventType}/events/{eventId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Fallback: deny by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
