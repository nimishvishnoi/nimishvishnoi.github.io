{
  "rules": {
    ".read": false,
    ".write": false,
    "admins": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid"
      }
    },
    "analytics": {
      "$eventType": {
        ".write": "auth == null || auth != null",
        ".read": "auth != null"
      }
    },
    "content": {
      "$type": {
        "$id": {
          ".read": true,
          ".write": "auth != null"
        }
      }
    },
    "Message": {
      ".read": "auth != null",
      "$date": {
        ".validate": "$date.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)",
        "$messageId": {
          ".write": "(!data.exists() && newData.exists()) || (data.exists() && !newData.exists() && auth != null)",
          ".validate": "newData.hasChildren(['name','email','subject','message','createdAt','submittedAt','origin','validationMethod','recaptchaStatus']) && newData.hasOnly(['name','email','phone','subject','message','createdAt','submittedAt','origin','validationMethod','recaptchaStatus'])",
          "name": {
            ".validate": "newData.isString() && newData.val().length >= 4 && newData.val().length <= 100"
          },
          "email": {
            ".validate": "newData.isString() && newData.val().length <= 254 && newData.val().matches(/^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/)"
          },
          "phone": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 30 && newData.val().matches(/^[\\d\\s\\-+()]*$/))"
          },
          "subject": {
            ".validate": "newData.isString() && newData.val().length >= 8 && newData.val().length <= 150"
          },
          "message": {
            ".validate": "newData.isString() && newData.val().length >= 10 && newData.val().length <= 2000"
          },
          "createdAt": { ".validate": "newData.isNumber() && newData.val() == now" },
          "submittedAt": { ".validate": "newData.isString() && newData.val().length <= 40" },
          "recaptchaStatus": {
            ".validate": "newData.isString() && newData.val().matches(/^(token-generated|not-configured)$/)"
          },
          "origin": { ".validate": "newData.isString() && newData.val().length <= 120" },
          "validationMethod": {
            ".validate": "newData.isString() && newData.val().matches(/^(client-validation|client-validation\\+recaptcha)$/)"
          },
          "$other": { ".validate": false }
        }
      }
    }
  }
}
